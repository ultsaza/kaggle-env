# direnv auto-activation requires the Nix store to be visible on the host
# filesystem. With nix-portable the store lives inside its own sandbox and /nix
# does not exist here, so `use flake` would only export dead /nix/store paths
# (uv, python, ...) and break the shell. Detect that and skip activation,
# pointing at `nix develop` instead.
if [ -d /nix/store ]; then
  use flake
  watch_file uv.lock

  if [ "${KAGGLE_UV_SYNC:-1}" != "0" ]; then
    "${KAGGLE_UV:-uv}" sync
  fi

  source .venv/bin/activate
  # Also called from flake.nix's shellHook, but that call runs before this
  # file's `uv sync` above on a fresh venv (shellHook's own sync defaults to
  # off under direnv) and would see zero packages to patch. This call is the
  # one that actually catches a first-time clone; do not remove it as a
  # "duplicate" of the shellHook call.
  ./bin/kaggle-patch-venv
  PATH_add bin
else
  log_status "nix-portable mode: /nix not on host, skipping flake activation."
  log_status "Run 'nix develop' (or: nix develop --command python main.py) to enter the env."
fi
