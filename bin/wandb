#!/usr/bin/env bash
set -euo pipefail

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

[ -n "${VIRTUAL_ENV:-}" ] || die "VIRTUAL_ENV is not set; enter the dev shell first."
[ -n "${KAGGLE_NATIVE_LIBRARY_PATH:-}" ] || die "KAGGLE_NATIVE_LIBRARY_PATH is not set; enter the dev shell first."

wandb_bin="$VIRTUAL_ENV/bin/wandb"
[ -x "$wandb_bin" ] || die "wandb is not installed in $VIRTUAL_ENV. Run uv sync first."

export LD_LIBRARY_PATH="$KAGGLE_NATIVE_LIBRARY_PATH${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
exec "$wandb_bin" "$@"
